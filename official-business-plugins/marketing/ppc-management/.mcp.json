{
  "ppc-gtm": {
    "command": "bash",
    "args": [
      "${CLAUDE_PLUGIN_ROOT}/bin/python_shim.sh",
      "${CLAUDE_PLUGIN_ROOT}/mcp_servers/gtm/server.py"
    ],
    "env": {
      "PPC_VAULT_PATH": "${CLAUDE_PLUGIN_DATA}/tokens.enc",
      "PPC_VAULT_PASSPHRASE": "${user_config.ppc_vault_passphrase}",
      "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_ROOT}/scripts",
      "CLAUDE_PLUGIN_OPTION_GOOGLE_ADS_DEVELOPER_TOKEN": "${user_config.google_ads_developer_token}",
      "CLAUDE_PLUGIN_OPTION_META_APP_ID": "${user_config.meta_app_id}",
      "CLAUDE_PLUGIN_OPTION_META_APP_SECRET": "${user_config.meta_app_secret}"
    }
  },
