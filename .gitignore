# Web Lifter OS lives in its own repo (https://github.com/johnoconnor0/johns-os).
# The local clone may sit at this path for development convenience, but
# nothing inside it should be committed to official-claude-plugins.
johns-os/

# Local Claude Code overrides — never commit personal settings.
.claude/settings.local.json
# Transient marker written by the stack-command plugin's SessionStart hook
# (records the detected workspace root); runtime state, never committed.
.claude/.stack-command-active

# Python bytecode (generated by smoke-tests of skills/*/scripts/*.py)
__pycache__/
*.pyc
*.pyo
*.pyd

# Python virtual envs created locally (e.g. by official-business-plugins/marketing/ppc-management scripts)
.venv/
venv/
env/
.env

# Node tooling
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Build / test output (not produced by repo scripts today, but pre-empt)
dist/
build/
coverage/
.nyc_output/

# Skill eval harness — transient artefacts dropped in cwd by run-eval.
# Per-skill eval suites + iteration logs ARE tracked (under evals/);
# what gets ignored is the cwd-side run reports until someone moves them
# into audits/.
skill-eval-run-*.md
skill-eval-run-*.json
skill-evaluation-*.md
skill-evaluation-*.json

# Local dry-run outputs from tune-criteria.mjs and similar scripts.
tune-result.json

# Local VirusTotal cache. Canonical raw JSON now lives under .project/virustotal/
# (gitignored — see .project rule below). The consolidated report VIRUSTOTAL.md
# at the repo root IS tracked.
.vt-cache/
.virustotal/

# Lock files for ad-hoc local installs (PPC manager's pip lockfile lives
# under official-business-plugins/marketing/ppc-management/ and IS tracked;
# root-level transient ones are not).
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# Claude Code plugin runtime data (Claude writes to ~/.claude/plugins/data/,
# but if a user ever puts a symlink in-repo we still don't want it staged).
plugin-data/

# Logs and temp files
*.log
*.tmp
tmp/
temp/

# Local-only PostHog admin utilities (require POSTHOG_MASTER_KEY env)
scripts/patch-posthog-evals.py



# Internal Web Lifter observability plugin — not for end users
internal-utilities/observability/

# Cached copies of external Claude Code documentation pages fetched at runtime.
# Always available fresh from code.claude.com — tracking them bloats the repo.
.project/.docs/
internal-utilities

# Engineering OS workspace — johns-os/engineering-os/eng-* plugins write
# initiative artefacts (profiles, service catalog, decisions, handoffs, work)
# under .eng-os/ at the consumer's repo root. May contain sensitive org/system
# data. Never committed; downstream consumers should also gitignore this.
.eng-os/

## Plugins
official-business-plugins/startups
ai-utility-plugins/resource-manager


.project

# venture-os workspaces — created by the SessionStart hook. Named workspaces
# (.venture-os-<name>/) are registered in the plugin's variables.json and may
# live in any project; we ignore them here so they're never committed by accident.
.venture-os/
.venture-os-*/
